# Database (required)
DATABASE_URL="postgresql://finhealth:finhealth_dev@localhost:5432/finhealth?schema=public"

# Auth (required in production — app will crash without it)
JWT_SECRET="change-me-to-a-random-64-char-string"

# Server
PORT=3001
NODE_ENV=development

# CORS (defaults to http://localhost:5173 in dev)
CORS_ORIGIN="http://localhost:5173"

# Logging (defaults: "debug" in dev, "info" in production)
# LOG_LEVEL="info"
