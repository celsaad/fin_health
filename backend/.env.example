# Database (required)
DATABASE_URL="postgresql://finhealth:finhealth_dev@localhost:5432/finhealth?schema=public"

# Auth (required in production — app will crash without it)
JWT_SECRET="change-me-to-a-random-64-char-string"

# Server
PORT=3001
NODE_ENV=development

# CORS (defaults to http://localhost:5173 in dev)
CORS_ORIGIN="http://localhost:5173"

# Logging (defaults: "info")
# LOG_LEVEL="info"

# Sentry DSN for error monitoring (leave empty to disable)
# SENTRY_DSN=

# Stripe (required for billing — leave empty in dev if not testing payments)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# STRIPE_PRO_YEARLY_PRICE_ID=price_...

# Frontend URL (for Stripe redirect URLs)
# CLIENT_URL=http://localhost:5173
