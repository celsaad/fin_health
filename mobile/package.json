{
  "name": "@fin-health/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "./index.js",
  "scripts": {
    "dev": "expo start",
    "build": "expo export",
    "typecheck": "tsc --noEmit",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|lucide-react-native|@tanstack/.*|axios|@fin-health/shared)"
    ],
    "setupFiles": [
      "./jest.setup.ts"
    ],
    "testPathIgnorePatterns": [
      "/__tests__/test-utils"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@fin-health/shared": "*",
    "@gorhom/bottom-sheet": "^5.1.1",
    "@hookform/resolvers": "^5.0.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^7.3.0",
    "@react-navigation/native": "^7.1.0",
    "@react-navigation/native-stack": "^7.3.0",
    "@sentry/react-native": "~7.11.0",
    "@tanstack/react-query": "^5.62.0",
    "axios": "^1.7.0",
    "babel-preset-expo": "^55.0.10",
    "date-fns": "^4.1.0",
    "expo": "~55.0.0",
    "expo-asset": "^55.0.8",
    "expo-file-system": "^55.0.10",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-keep-awake": "^55.0.4",
    "expo-linear-gradient": "~55.0.8",
    "expo-modules-autolinking": "^55.0.8",
    "expo-modules-core": "^55.0.14",
    "expo-router": "~55.0.4",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "i18next": "^25.8.14",
    "is-arrayish": "^0.3.4",
    "lucide-react-native": "^0.468.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.54.0",
    "react-i18next": "^16.5.5",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-pager-view": "8.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-toast-message": "^2.2.0",
    "react-native-worklets": "^0.7.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "prettier": "^3.8.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.48.0"
  }
}
