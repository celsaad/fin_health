// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// Users Model
// ============================================================================

model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String   @unique @db.VarChar(255)
  passwordHash  String   @map("password_hash")
  currency      String   @default("USD") @db.VarChar(3)
  timezone      String   @default("America/New_York") @db.VarChar(100)
  monthStartDay Int      @default(1) @map("month_start_day")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  categories    Category[]
  subcategories Subcategory[]
  budgets       Budget[]
  expenses      Expense[]

  @@map("users")
}

// ============================================================================
// Categories Model
// ============================================================================

model Category {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  archived  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  subcategories     Subcategory[]
  budgetAllocations BudgetAllocation[]
  expenses          Expense[]

  @@unique([userId, name], name: "categories_user_name_unique")
  @@index([userId], name: "categories_user_id_idx")
  @@map("categories")
}

// ============================================================================
// Subcategories Model
// ============================================================================

model Subcategory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  name       String   @db.VarChar(100)
  sortOrder  Int      @default(0) @map("sort_order")
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category          Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  budgetAllocations BudgetAllocation[]
  expenses          Expense[]

  @@unique([categoryId, name], name: "subcategories_category_name_unique")
  @@index([userId], name: "subcategories_user_id_idx")
  @@index([categoryId], name: "subcategories_category_id_idx")
  @@map("subcategories")
}

// ============================================================================
// Budgets Model
// ============================================================================

model Budget {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  monthKey  String   @map("month_key") @db.VarChar(7) // Format: "YYYY-MM"
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocations BudgetAllocation[]

  @@unique([userId, monthKey], name: "budgets_user_month_key_unique")
  @@index([userId], name: "budgets_user_id_idx")
  @@map("budgets")
}

// ============================================================================
// Budget Allocations Model
// ============================================================================

model BudgetAllocation {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  budgetId      String   @map("budget_id") @db.Uuid
  categoryId    String   @map("category_id") @db.Uuid
  subcategoryId String?  @map("subcategory_id") @db.Uuid
  amountCents   Int      @map("amount_cents") // Money stored as integer cents
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  budget      Budget       @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subcategory Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)

  @@unique([budgetId, categoryId, subcategoryId], name: "budget_allocations_budget_cat_subcat_unique")
  @@index([budgetId], name: "budget_allocations_budget_id_idx")
  @@map("budget_allocations")
}

// ============================================================================
// Expenses Model
// ============================================================================

model Expense {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  occurredAt    DateTime @map("occurred_at") @db.Timestamptz
  amountCents   Int      @map("amount_cents") // Money stored as integer cents
  categoryId    String   @map("category_id") @db.Uuid
  subcategoryId String?  @map("subcategory_id") @db.Uuid
  notes         String?  @db.VarChar(500)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: Restrict)

  @@index([userId], name: "expenses_user_id_idx")
  @@index([occurredAt], name: "expenses_occurred_at_idx")
  @@index([categoryId], name: "expenses_category_id_idx")
  @@index([userId, occurredAt], name: "expenses_user_occurred_at_idx")
  @@map("expenses")
}
