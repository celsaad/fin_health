{
  "name": "@fin-health/db",
  "version": "1.0.0",
  "description": "Database schema and migrations using Drizzle ORM",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema.js",
    "./client": "./dist/client.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@fin-health/domain": "workspace:*",
    "drizzle-orm": "^0.35.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
