  "dependencies": {
    "@fin-health/domain": "workspace:*",
    "@remix-run/node": "^2.15.2",
    "@remix-run/react": "^2.15.2",
    "@remix-run/serve": "^2.15.2",
    "@supabase/supabase-js": "^2.39.3",
    "@trpc/client": "^10.45.0",
    "@trpc/server": "^10.45.0",
    "isbot": "^5.1.22",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "superjson": "^2.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.15.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.3",
    "vite": "^6.0.11",
    "vite-tsconfig-paths": "^5.1.4"
