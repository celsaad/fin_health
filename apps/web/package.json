{
  "name": "@fin-health/web",
  "version": "1.0.0",
  "description": "Remix web app for Fin Health",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "start": "remix-serve ./build/server/index.js",
